[Desktop Entry]
Version=1.0
Type=Application

Name=FIDE
Comment=Lightning-fast and powerful code editor written in Rust
Categories=Development;IDE;
GenericName=Code Editor
StartupWMClass=fide

Icon=dev.fide.fide
Exec=fide %F
Terminal=false
MimeType=text/plain;inode/directory;
Actions=new-window;

[Desktop Action new-window]
Name=New Window
Exec=fide --new %F
Icon=dev.fide.fide
